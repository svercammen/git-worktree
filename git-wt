def cmd_create(args, config: Config):
    """Create a new worktree with full environment setup."""
    # Always anchor to the main worktree root so base_dir doesn't nest paths
    # when cmd_create is invoked from inside a linked worktree.
    try:
        source_path = get_main_worktree_root()
    except Exception:
        print("Error: Not in a git repository", file=sys.stderr)
        sys.exit(1)

    name = args.name
    branch = args.branch or name

    # Check for running JetBrains IDE up front — IDE setup will fail later
    # otherwise, leaving a half-built worktree (deps installed, no IDE config).
    if not args.no_ide:
        running_ides = get_running_jetbrains_ides()
        if running_ides:
            print(
                f"Error: JetBrains IDE is running ({', '.join(running_ides)}). "
                "It would overwrite jdk.table.xml edits on shutdown, breaking the "
                "SDK registration. Close it and re-run `git wt create`, or pass "
                "--no-ide to skip IDE setup.",
                file=sys.stderr,
            )
            sys.exit(1)

    # Resolve branch: existing → fetch if remote → create from main
    existence = branch_exists_where(branch)
    if existence is None:
        ls_remote = run_cmd(["git", "ls-remote", "--heads", "origin", branch], check=False)
        if ls_remote.returncode != 0:
            print("Warning: could not reach origin, proceeding with local state", file=sys.stderr)
        elif ls_remote.stdout.strip():
            print(f"Branch '{branch}' exists on origin — fetching...")
            fetch_result = run_cmd(["git", "fetch", "origin", branch], check=False)
            if fetch_result.returncode != 0:
                print("Warning: fetch failed, proceeding with local state", file=sys.stderr)
            existence = branch_exists_where(branch)

    if existence is None:
        base = args.base or "main"
        print(f"Creating new branch '{branch}' from '{base}'...")
        try:
            run_cmd(["git", "branch", branch, base])
        except subprocess.CalledProcessError:
            sys.exit(1)
    else:
        if args.base:
            print(
                f"Warning: --base ignored: branch '{branch}' already exists",
                file=sys.stderr,
            )
        occupying = find_worktree_for_branch(branch)
        if occupying is not None:
            print(
                f"Error: branch '{branch}' is already checked out at {occupying}.\n"
                f"Use `wt {branch}` to switch, or pick a different branch.",
                file=sys.stderr,
            )
            sys.exit(1)

    # Resolve worktree path
    if args.path:
        worktree_path = Path(args.path).resolve()
    else:
        base_dir = config.base_dir.replace("{repo}", get_repo_name())
        base_path = (source_path / base_dir).resolve()
        base_path.mkdir(parents=True, exist_ok=True)
        worktree_path = base_path / name.replace("/", "-")

    if worktree_path.exists():
        # Check if it's an orphaned directory (not registered as a git worktree)
        registered = {Path(wt["path"]) for wt in get_worktrees()}
        if worktree_path.resolve() not in registered:
            print(f"Removing orphaned directory at {worktree_path}...")
            shutil.rmtree(worktree_path)
        else:
            print(f"Error: Path '{worktree_path}' already exists", file=sys.stderr)
            sys.exit(1)

    # Create worktree
    print(f"Creating worktree at {worktree_path}...")
    try:
        run_cmd(["git", "worktree", "add", str(worktree_path), branch])
    except Exception as e:
        print(f"Error: Failed to create worktree: {e}", file=sys.stderr)
        sys.exit(1)

    # Detect projects
    print("Detecting projects...")
    projects = detect_projects(source_path)
    print(f"Found {len(projects)} projects: {', '.join(p.name for p in projects)}")

    # Install dependencies
    venv_paths = {}
    if not args.no_install:
        try:
            venv_paths = install_dependencies(worktree_path, projects, source_path=source_path)
        except Exception as e:
            print(f"Warning: Dependency installation failed: {e}", file=sys.stderr)
            print(f"You can clean up with: git wt remove {worktree_path}", file=sys.stderr)

    # Set up IDE (running-IDE check happened up front)
    if not args.no_ide:
        try:
            setup_jetbrains(source_path, worktree_path, venv_paths)
            setup_vscode(source_path, worktree_path, projects, venv_paths)
        except Exception as e:
            print(f"Warning: IDE setup failed: {e}", file=sys.stderr)

    # Handle .env files
    try:
        handle_env_files(source_path, worktree_path, projects, copy=args.copy_env)
    except Exception as e:
        print(f"Warning: .env file handling failed: {e}", file=sys.stderr)

    # Handle Terraform .tfvars files
    try:
        handle_tfvars_files(source_path, worktree_path, copy=args.copy_env)
    except Exception as e:
        print(f"Warning: .tfvars file handling failed: {e}", file=sys.stderr)

    # Handle .claude/ directory
    try:
        handle_claude_config(source_path, worktree_path)
    except Exception as e:
        print(f"Warning: .claude/ symlink failed: {e}", file=sys.stderr)

    # Open editor
    editor = args.editor or config.editor
    if not args.no_open and config.open_editor:
        open_editor(editor, worktree_path)

    print(f"\n✓ Worktree created at {worktree_path}")

    if getattr(args, "cd_file", None) and not args.no_cd:
        try:
            Path(args.cd_file).write_text(str(worktree_path))
        except Exception:
            pass


def cmd_shell_init():
    """Print shell integration code for eval in .zshrc / .bashrc."""
    completions_dir = Path(__file__).resolve().parent / "completions"
    print(f"""# git-wt shell integration — added by: eval "$(git wt shell-init)"
fpath=({completions_dir} $fpath)
# Explicitly register completion — works even when eval runs after oh-my-zsh/compinit
autoload -Uz _wt
(( ${{+functions[compdef]}} )) && compdef _wt wt""")
    print(r"""
wt() {
  if [[ $# -eq 0 ]]; then
    # TUI mode: pass temp files so the script can communicate cd path and expanded command back
    local _wt_cd _wt_cmd _exit
    _wt_cd=$(mktemp)
    _wt_cmd=$(mktemp)
    git wt --cd-file="$_wt_cd" --cmd-file="$_wt_cmd"
    _exit=$?
    if [[ $_exit -eq 0 && -s "$_wt_cd" ]]; then
      builtin cd "$(cat "$_wt_cd")"
    fi
    if [[ -s "$_wt_cmd" ]]; then
      local _cmd
      _cmd=$(cat "$_wt_cmd")
      print -s "$_cmd"
      if command -v atuin &>/dev/null && atuin history list &>/dev/null 2>&1; then
        local _atuin_id
        _atuin_id=$(atuin history start -- "$_cmd" 2>/dev/null)
        [[ -n "$_atuin_id" ]] && atuin history end --exit $_exit "$_atuin_id" 2>/dev/null
      fi
    fi
    rm -f "$_wt_cd" "$_wt_cmd"
    return $_exit
  elif [[ "$1" == "create" ]]; then
    local _wt_tmp
    _wt_tmp=$(mktemp)
    git wt create "${@:2}" --cd-file="$_wt_tmp"
    local _exit=$?
    if [[ $_exit -eq 0 && -s "$_wt_tmp" ]]; then
      builtin cd "$(cat "$_wt_tmp")"
    fi
    rm -f "$_wt_tmp"
    return $_exit
  elif [[ "$1" == "switch" || "$1" == "-" || ( $# -eq 1 && "$1" != "--" && ! "$1" =~ ^- ) ]]; then
    local _wt_tmp
    _wt_tmp=$(mktemp)
    git wt "$@" --cd-file="$_wt_tmp"
    local _exit=$?
    if [[ $_exit -eq 0 && -s "$_wt_tmp" ]]; then
      builtin cd "$(cat "$_wt_tmp")"
    fi
    rm -f "$_wt_tmp"
    return $_exit
  else
    git wt "$@"
  fi
}""")


def cmd_remove(args, config):
    """Destroy one or more worktrees and clean up their environments."""
    # Resolve all targets first; fail fast if any is unknown
    resolved: List[Path] = []
    for target in args.targets:
        worktree_path = resolve_worktree(target, config)
        if not worktree_path:
            print(f"Error: Worktree '{target}' not found", file=sys.stderr)
            sys.exit(1)
        resolved.append(worktree_path)

    # Deduplicate while preserving order (user may type same branch + path, etc.)
    seen: Set[Path] = set()
    unique: List[Path] = []
    for p in resolved:
        if p not in seen:
            seen.add(p)
            unique.append(p)

    # Check for running JetBrains IDE before prompting — avoids confirming
    # only to fail.
    running_ides = get_running_jetbrains_ides()
    if running_ides:
        print(
            f"Error: JetBrains IDE is running ({', '.join(running_ides)}). "
            "It would overwrite jdk.table.xml edits on shutdown, leaving stale "
            "SDK entries behind. Close it and re-run `git wt remove`.",
            file=sys.stderr,
        )
        sys.exit(1)

    # Confirm once unless --force
    if not args.force:
        if len(unique) == 1:
            response = input(f"Destroy worktree at {unique[0]}? [y/N] ")
        else:
            print("Destroy the following worktrees:")
            for p in unique:
                print(f"  {p}")
            response = input(f"Proceed with removal of {len(unique)} worktrees? [y/N] ")
        if response.lower() != "y":
            print("Cancelled")
            return

    failures = 0
    for worktree_path in unique:
        print(f"\nDestroying worktree at {worktree_path}...")

        try:
            docker_compose_down(worktree_path)
        except Exception as e:
            print(f"Warning: docker compose down failed: {e}", file=sys.stderr)

        try:
            unregister_jetbrains_sdks(worktree_path)
        except Exception as e:
            print(f"Warning: Failed to clean up JetBrains SDKs: {e}", file=sys.stderr)

        for venv in worktree_path.glob("*/.venv"):
            if venv.is_dir():
                print(f"Removing {venv}...")
                shutil.rmtree(venv)

        for nm in worktree_path.glob("*/node_modules"):
            if nm.is_dir():
                print(f"Removing {nm}...")
                shutil.rmtree(nm)

        try:
            run_cmd(["git", "worktree", "remove", str(worktree_path), "--force"])
            print(f"✓ Worktree removed: {worktree_path}")
        except Exception as e:
            print(f"Error: Failed to remove worktree {worktree_path}: {e}", file=sys.stderr)
            failures += 1

    try:
        run_cmd(["git", "worktree", "prune"])
    except Exception:
        pass

    if failures:
        sys.exit(1)


def get_worktrees() -> list:
    """Return parsed worktree list. Each item has: path, branch, is_main."""
    result = run_cmd(["git", "worktree", "list", "--porcelain"])
    worktrees = []
    current: dict = {}
    for line in result.stdout.splitlines():
        if line.startswith("worktree "):
            if current:
                worktrees.append(current)
            current = {"path": Path(line.split(" ", 1)[1])}
        elif line.startswith("branch "):
            current["branch"] = line.split(" ", 1)[1].replace("refs/heads/", "")
        elif line.startswith("bare"):
            current["bare"] = True
    if current:
        worktrees.append(current)
    for i, wt in enumerate(worktrees):
        wt["is_main"] = (i == 0)
        wt.setdefault("branch", "")
    return worktrees


def cmd_list(args):
    """List all worktrees with status indicators."""
    worktrees = get_worktrees()

    for wt in worktrees:
        path = wt["path"]
        branch = wt.get("branch", "")

        indicators = []

        # Check for IDE configs
        if (path / ".idea").exists():
            indicators.append("idea")
        if (path / ".vscode").exists():
            indicators.append("vscode")

        # Check for venvs
        venv_count = len(list(path.glob("*/.venv")))
        poetry_count = len(list(path.glob("*/poetry.lock")))
        if venv_count > 0:
            indicators.append(f"{venv_count}/{poetry_count} venvs")

        # Check for node_modules
        if list(path.glob("*/node_modules")):
            indicators.append("node_modules")

        status = f"[{', '.join(indicators)}]" if indicators else ""
        print(f"{path}")
        if branch:
            print(f"  branch: {branch}")
        if status:
            print(f"  status: {status}")
        print()


def cmd_switch(args):
    """Switch to a worktree by partial branch/path match. '-' goes to the main worktree."""
    name = args.name
    worktrees = get_worktrees()

    if name == "-":
        target = next((wt["path"] for wt in worktrees if wt.get("is_main")), None)
        if not target:
            print("Error: No main worktree found", file=sys.stderr)
            sys.exit(1)
    else:
        matches = [
            wt for wt in worktrees
            if name.lower() in wt.get("branch", "").lower()
            or name.lower() in str(wt["path"]).lower()
        ]
        if not matches:
            print(f"Error: No worktree matching '{name}'", file=sys.stderr)
            sys.exit(1)
        if len(matches) > 1:
            print(f"Error: Multiple worktrees match '{name}':", file=sys.stderr)
            for m in matches:
                print(f"  {m.get('branch') or m['path']}", file=sys.stderr)
            sys.exit(1)
        target = matches[0]["path"]

    print(f"Switching to {target}...")
    if getattr(args, "cd_file", None):
        try:
            Path(args.cd_file).write_text(str(target))
        except Exception:
            pass


def resolve_worktree(path_or_branch: str, config: Optional["Config"] = None) -> Optional[Path]:
    """Resolve a worktree path from a path or branch name."""
    # Try as direct path
    path = Path(path_or_branch)
    if path.exists():
        return path.resolve()

    # Try to find in registered worktree list
    result = run_cmd(["git", "worktree", "list", "--porcelain"])
    current_path = None

    for line in result.stdout.splitlines():
        if line.startswith("worktree "):
            current_path = Path(line.split(" ", 1)[1])
        elif line.startswith("branch ") and current_path:
            branch = line.split(" ", 1)[1].replace("refs/heads/", "")
            if branch == path_or_branch or branch.endswith(f"/{path_or_branch}"):
                return current_path
            current_path = None

    # Fall back to the computed path based on config (catches orphaned/unregistered dirs)
    if config is not None:
        try:
            source_path = get_main_worktree_root()
            base_dir = config.base_dir.replace("{repo}", get_repo_name())
            computed = (source_path / base_dir / path_or_branch.replace("/", "-")).resolve()
            if computed.exists():
                return computed
        except Exception:
            pass

    return None


# --- TUI ---

def run_tui() -> Optional[List[str]]:
    """Show an interactive TUI when invoked with no arguments.

    Returns a list of argv tokens (e.g. ["create", "my-worktree", "--branch", "feature/foo"])
    to inject into sys.argv before argparse runs, or None if the user cancelled.
    """
    import curses

    COMMANDS = ["create", "remove", "list"]
    FIELD_W = 38  # visible width of text input boxes

    class State:
        def __init__(self):
            self.tab = 0
            self.focus = 0
            self.error = ""
            # create
            self.name = "";       self.name_cur = 0
            self.branch = "";     self.branch_cur = 0
            self.base = "";       self.base_cur = 0
            self.no_install = False
            self.no_open  = False
            self.no_cd      = False
            self.no_ide     = False
            self.copy_env   = False
            # remove
            self.remove_pick = 0  # cursor position in _removable
            self.remove_selected: Set[int] = set()  # indices of checked worktrees
            self.force = False

    # Fetch worktrees once for remove picker and list tab
    try:
        _all_worktrees = get_worktrees()
    except Exception:
        _all_worktrees = []
    _removable = [wt for wt in _all_worktrees if not wt.get("is_main")]

    # (attr, label, is_cb, hint, placeholder, required)
    # is_cb: False = text input, True = checkbox,
    #        "select" = ←/→ option picker, "multi" = ↑/↓ list with Space to toggle
    CREATE_FIELDS = [
        ("name",         "Name:         ", False,    "worktree directory name",                        "",                     True),
        ("branch",       "Branch:       ", False,    "branch to check out",                            "<name> (if omitted)",  False),
        ("base",         "Base:         ", False,    "start-point for a new branch (only used when branch doesn't exist)", "main (if omitted)",    False),
        ("no_install",   "--no-install  ", True,     "skip dependency installation",                   "",                     False),
        ("no_open",      "--no-open     ", True,     "don't launch the editor after create",           "",                     False),
        ("no_cd",        "--no-cd       ", True,     "don't cd into the worktree after creation",      "",                     False),
        ("no_ide",       "--no-ide      ", True,     "skip IDE configuration",                         "",                     False),
        ("copy_env",     "--copy-env    ", True,     "copy .env files instead of symlinking",          "",                     False),
    ]
    REMOVE_FIELDS = [
        ("remove_selected", "Worktrees:    ", "multi",  "Space: toggle, ↑↓: move",   "", True),
        ("force",           "--force       ", True,     "skip confirmation prompt",  "", False),
    ]
    LIST_FIELDS: list = []
    FIELDS_BY_TAB = [CREATE_FIELDS, REMOVE_FIELDS, LIST_FIELDS]

    s = State()

    def cur_fields():
        return FIELDS_BY_TAB[s.tab]

    def build_argv() -> List[str]:
        cmd = COMMANDS[s.tab]
        if cmd == "create":
            parts: List[str] = ["create"]
            if s.name:        parts.append(s.name)
            if s.branch:      parts += ["--branch", s.branch]
            if s.base:        parts += ["--base", s.base]
            if s.no_install:  parts.append("--no-install")
            if s.no_open:     parts.append("--no-open")
            if s.no_cd:       parts.append("--no-cd")
            if s.no_ide:      parts.append("--no-ide")
            if s.copy_env:    parts.append("--copy-env")
        elif cmd == "remove":
            parts = ["remove"]
            for idx in sorted(s.remove_selected):
                if idx < len(_removable):
                    wt = _removable[idx]
                    parts.append(wt.get("branch") or str(wt["path"]))
            if s.force:   parts.append("--force")
        else:
            parts = ["list"]
        return parts

    def get_text(attr: str) -> tuple:
        return getattr(s, attr), getattr(s, attr + "_cur")

    def set_text(attr: str, text: str, cur: int):
        setattr(s, attr, text)
        setattr(s, attr + "_cur", cur)

    def handle_text_key(attr: str, key: int):
        text, cur = get_text(attr)
        if key in (curses.KEY_BACKSPACE, 127, 8):
            if cur > 0:
                set_text(attr, text[:cur - 1] + text[cur:], cur - 1)
        elif key == curses.KEY_DC:
            if cur < len(text):
                set_text(attr, text[:cur] + text[cur + 1:], cur)
        elif key == curses.KEY_LEFT:
            set_text(attr, text, max(0, cur - 1))
        elif key == curses.KEY_RIGHT:
            set_text(attr, text, min(len(text), cur + 1))
        elif key == curses.KEY_HOME:
            set_text(attr, text, 0)
        elif key == curses.KEY_END:
            set_text(attr, text, len(text))
        elif 32 <= key < 127:
            set_text(attr, text[:cur] + chr(key) + text[cur:], cur + 1)

    def draw(stdscr):
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        cursor_pos = None
        row = 0

        # Title
        stdscr.addstr(row, 2, "git wt", curses.A_BOLD)
        row += 1
        stdscr.addstr(row, 2, "─" * min(w - 4, 60))
        row += 1

        # Tab bar
        x = 2
        for i, cmd in enumerate(COMMANDS):
            label = f" {cmd} "
            attr = curses.A_REVERSE | curses.A_BOLD if i == s.tab else curses.A_DIM
            stdscr.addstr(row, x, label, attr)
            x += len(label) + 1
        stdscr.addstr(row, x + 1, "Tab/Shift+Tab: switch tab", curses.A_DIM)
        row += 2

        # Form fields
        fields = cur_fields()
        for i, (attr, label, is_cb, hint, placeholder, required) in enumerate(fields):
            is_focused = (i == s.focus)
            # is_missing: text fields only; selectors missing if nothing picked
            if required and is_cb == "multi":
                is_missing = not s.remove_selected
            elif required and is_cb == "select":
                is_missing = not _removable
            elif required and not is_cb:
                is_missing = not getattr(s, attr)
            else:
                is_missing = False
            col = 4

            # Required marker (* at col 2, dimmed when filled, bold when missing)
            if required:
                marker_attr = curses.A_BOLD if is_missing else curses.A_DIM
                stdscr.addstr(row, 2, "*", marker_attr)

            if is_cb == "multi":
                fa = curses.A_BOLD if is_focused else 0
                stdscr.addstr(row, col, label, fa)
                summary_x = col + len(label)
                if not _removable:
                    stdscr.addstr(row, summary_x, "(no linked worktrees)", curses.A_DIM)
                    row += 1
                else:
                    n = len(_removable)
                    selected_n = len(s.remove_selected)
                    stdscr.addstr(row, summary_x, f"{selected_n}/{n} selected", curses.A_DIM)
                    if hint and is_focused:
                        hint_x = summary_x + len(f"{selected_n}/{n} selected") + 3
                        if hint_x + len(hint) < w - 1:
                            stdscr.addstr(row, hint_x, hint, curses.A_DIM)
                    row += 1
                    for idx, wt in enumerate(_removable):
                        if row >= h - 5:  # leave room for preview + help
                            stdscr.addstr(row, col + 2, f"… {n - idx} more (resize terminal)", curses.A_DIM)
                            row += 1
                            break
                        val = wt.get("branch") or str(wt["path"].name)
                        checked = "[x]" if idx in s.remove_selected else "[ ]"
                        at_cursor = is_focused and idx == s.remove_pick
                        marker = "▶" if at_cursor else " "
                        line = f"{marker} {checked} {val}"
                        line_attr = curses.A_REVERSE if at_cursor else 0
                        try:
                            stdscr.addstr(row, col + 2, line[:w - col - 4], line_attr)
                        except curses.error:
                            pass
                        row += 1
                continue  # skip the default row += 1 below
            elif is_cb == "select":
                fa = curses.A_BOLD if is_focused else 0
                stdscr.addstr(row, col, label, fa)
                field_x = col + len(label)
                if _removable:
                    wt = _removable[s.remove_pick]
                    val = wt.get("branch") or str(wt["path"].name)
                    n = len(_removable)
                    display = f"◂ {val} ▸  ({s.remove_pick + 1}/{n})"
                    display = display[:FIELD_W].ljust(FIELD_W)
                    field_attr = curses.A_REVERSE if is_focused else curses.A_UNDERLINE
                    stdscr.addstr(row, field_x, display, field_attr)
                else:
                    stdscr.addstr(row, field_x, " (no linked worktrees) ".ljust(FIELD_W), curses.A_DIM | curses.A_UNDERLINE)
                if hint:
                    hint_x = field_x + FIELD_W + 2
                    if hint_x + len(hint) < w - 1:
                        stdscr.addstr(row, hint_x, hint, curses.A_DIM)
            elif is_cb:
                val = getattr(s, attr)
                checkbox = "[x]" if val else "[ ]"
                fa = curses.A_BOLD if is_focused else 0
                stdscr.addstr(row, col, checkbox, fa)
                stdscr.addstr(row, col + 4, label, fa)
                stdscr.addstr(row, col + 4 + len(label), hint, curses.A_DIM)
            else:
                text, cur = get_text(attr)
                fa = curses.A_BOLD if is_focused else 0
                stdscr.addstr(row, col, label, fa)
                field_x = col + len(label)
                if text:
                    scroll = max(0, cur - FIELD_W + 1)
                    display = text[scroll:scroll + FIELD_W].ljust(FIELD_W)
                    field_attr = curses.A_REVERSE if is_focused else curses.A_UNDERLINE
                    stdscr.addstr(row, field_x, display, field_attr)
                    if is_focused:
                        cursor_pos = (row, field_x + (cur - scroll))
                elif placeholder:
                    ph = placeholder[:FIELD_W].ljust(FIELD_W)
                    stdscr.addstr(row, field_x, ph, curses.A_DIM | curses.A_UNDERLINE)
                    if is_focused:
                        cursor_pos = (row, field_x)
                else:
                    stdscr.addstr(row, field_x, " " * FIELD_W, curses.A_UNDERLINE)
                    if is_focused:
                        cursor_pos = (row, field_x)
                # Hint after the input box
                if hint:
                    hint_x = field_x + FIELD_W + 2
                    if hint_x + len(hint) < w - 1:
                        stdscr.addstr(row, hint_x, hint, curses.A_DIM)
            row += 1

        if not fields:
            # List tab: show worktrees table
            if _all_worktrees:
                for wt in _all_worktrees:
                    branch = wt.get("branch", "")
                    path = wt["path"]
                    marker = "●" if wt.get("is_main") else "○"
                    line = f"{marker} {branch or path.name}"
                    try:
                        stdscr.addstr(row, 4, line[:w - 6])
                    except curses.error:
                        pass
                    row += 1
                    try:
                        stdscr.addstr(row, 6, str(path)[:w - 8], curses.A_DIM)
                    except curses.error:
                        pass
                    row += 1
            else:
                stdscr.addstr(row, 4, "(no worktrees found)", curses.A_DIM)
                row += 1

        # Error message (shown when user tries to submit with missing required fields)
        row += 1
        if s.error:
            stdscr.addstr(row, 2, s.error, curses.A_BOLD)
        row += 1

        # Preview
        stdscr.addstr(row, 2, "─" * min(w - 4, 60), curses.A_DIM)
        row += 1
        preview = "$ git wt " + " ".join(build_argv())
        stdscr.addstr(row, 2, preview[:w - 4], curses.A_BOLD)
        row += 1
        stdscr.addstr(row, 2, "─" * min(w - 4, 60), curses.A_DIM)
        row += 1

        # Help
        stdscr.addstr(row, 2, "↑↓: next field   ←/→: cycle option   Space: toggle   Enter: run   Esc: quit", curses.A_DIM)

        # Place hardware cursor
        if cursor_pos:
            curses.curs_set(1)
            try:
                stdscr.move(*cursor_pos)
            except curses.error:
                pass
        else:
            curses.curs_set(0)

        stdscr.refresh()

    def tui(stdscr):
        curses.curs_set(0)
        curses.use_default_colors()

        while True:
            draw(stdscr)
            key = stdscr.getch()

            fields = cur_fields()
            cur_field = fields[s.focus] if fields else None

            if key == 27:  # Esc
                return None

            # Tab switching
            elif key in (9, ord('['), ord(']')):    # Tab / [ / ]
                direction = -1 if key == ord('[') else 1
                s.tab = (s.tab + direction) % len(COMMANDS)
                s.focus = 0
                s.error = ""
            elif key == curses.KEY_BTAB:            # Shift-Tab
                s.tab = (s.tab - 1) % len(COMMANDS)
                s.focus = 0
                s.error = ""

            # Field navigation — multi-select captures ↑/↓ to move within its list,
            # wrapping to adjacent fields at the top/bottom.
            elif key == curses.KEY_DOWN:
                if cur_field and cur_field[2] == "multi" and _removable:
                    if s.remove_pick < len(_removable) - 1:
                        s.remove_pick += 1
                    else:
                        s.focus = (s.focus + 1) % len(fields)
                elif fields:
                    s.focus = (s.focus + 1) % len(fields)
            elif key == curses.KEY_UP:
                if cur_field and cur_field[2] == "multi" and _removable:
                    if s.remove_pick > 0:
                        s.remove_pick -= 1
                    else:
                        s.focus = (s.focus - 1) % len(fields)
                elif fields:
                    s.focus = (s.focus - 1) % len(fields)

            # Enter: validate + run
            elif key in (10, 13):
                def field_missing(f):
                    _, _, is_cb, _, _, required = f
                    if not required:
                        return False
                    if is_cb == "multi":
                        return not s.remove_selected
                    if is_cb == "select":
                        return not _removable
                    if is_cb:
                        return False
                    return not getattr(s, f[0])
                missing = [f for f in cur_fields() if field_missing(f)]
                if missing:
                    label_text = missing[0][1].strip().rstrip(":")
                    if missing[0][2] == "multi":
                        s.error = f"  select at least one {label_text.lower().rstrip('s')}"
                    else:
                        s.error = f"  {label_text} is required"
                    s.focus = cur_fields().index(missing[0])
                else:
                    return build_argv()

            # Select field: ←/→ to cycle options
            elif cur_field and cur_field[2] == "select":
                if key == curses.KEY_LEFT and _removable:
                    s.remove_pick = (s.remove_pick - 1) % len(_removable)
                elif key == curses.KEY_RIGHT and _removable:
                    s.remove_pick = (s.remove_pick + 1) % len(_removable)

            # Space: toggle multi-select item, checkbox, or insert space in text field
            elif key == ord(' '):
                if cur_field and cur_field[2] == "multi" and _removable:
                    s.error = ""
                    if s.remove_pick in s.remove_selected:
                        s.remove_selected.discard(s.remove_pick)
                    else:
                        s.remove_selected.add(s.remove_pick)
                elif cur_field and cur_field[2] is True:
                    setattr(s, cur_field[0], not getattr(s, cur_field[0]))
                elif cur_field and cur_field[2] != "select":
                    s.error = ""
                    handle_text_key(cur_field[0], key)

            # Text input for focused text field
            elif cur_field and not cur_field[2]:
                s.error = ""
                handle_text_key(cur_field[0], key)

    return curses.wrapper(tui)


# --- Main ---

def main():
    # Extract global pass-through flags before argparse sees them.
    # --cd-file and --cmd-file are injected by the shell function for TUI mode
    # and must survive subcommand dispatch without confusing argparse.
    _cd_file = None
    _cmd_file = None
    filtered = []
    for arg in sys.argv[1:]:
        if arg.startswith("--cd-file="):
            _cd_file = arg[len("--cd-file="):]
        elif arg.startswith("--cmd-file="):
            _cmd_file = arg[len("--cmd-file="):]
        else:
            filtered.append(arg)
    sys.argv[1:] = filtered

    _atuin_id = None  # set when we start an Atuin session to record TUI-produced commands

    if len(sys.argv) == 1:
        argv = run_tui()
        if argv is None:
            sys.exit(0)
        sys.argv[1:] = argv
        expanded = "git wt " + " ".join(argv)
        print(f"$ {expanded}")
        if _cmd_file:
            # Shell function is present — it will handle history injection
            try:
                Path(_cmd_file).write_text(expanded)
            except Exception:
                pass
        else:
            # Direct invocation (git wt) — inject into Atuin ourselves if available
            try:
                result = subprocess.run(
                    ["atuin", "history", "start", "--", expanded],
                    capture_output=True, text=True,
                )
                if result.returncode == 0:
                    _atuin_id = result.stdout.strip()
            except FileNotFoundError:
                pass  # atuin not installed
        # Re-inject --cd-file for commands that support it, produced by TUI
        if _cd_file and sys.argv[1] in ("create", "switch"):
            sys.argv.append(f"--cd-file={_cd_file}")

    parser = argparse.ArgumentParser(
        prog="git-wt",
        description="Git worktree manager with IDE and dependency setup"
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    # Create command
    create_parser = subparsers.add_parser("create", help="Create a new worktree")
    create_parser.add_argument("name", help="Worktree directory name (slashes are replaced with dashes)")
    create_parser.add_argument("--branch", help="Branch to check out (defaults to the worktree name)")
    create_parser.add_argument("--base", help="Start-point for a new branch (only used when branch doesn't exist; defaults to main)")
    create_parser.add_argument("--path", help="Custom worktree path")
    create_parser.add_argument("--no-install", action="store_true", help="Skip dependency installation")
    create_parser.add_argument("--no-open", action="store_true", help="Don't open editor")
    create_parser.add_argument("--no-ide", action="store_true", help="Skip IDE configuration")
    create_parser.add_argument("--copy-env", action="store_true", help="Copy .env files instead of symlinking")
    create_parser.add_argument("--editor", help="Editor command to use")
    create_parser.add_argument("--no-cd", action="store_true", help="Don't cd into the new worktree after creation")
    create_parser.add_argument("--cd-file", help=argparse.SUPPRESS)  # used by shell integration

    # Destroy command
    remove_parser = subparsers.add_parser("remove", help="Remove one or more worktrees")
    remove_parser.add_argument(
        "targets", nargs="+", metavar="PATH_OR_BRANCH",
        help="One or more worktree paths or branch names",
    )
    remove_parser.add_argument("-y", "--force", action="store_true", help="Skip confirmation prompt")

    # Switch command
    switch_parser = subparsers.add_parser("switch", help="Switch to a worktree by partial name ('-' for main)")
    switch_parser.add_argument("name", help="Partial branch name, path fragment, or '-' for main worktree")
    switch_parser.add_argument("--cd-file", help=argparse.SUPPRESS)  # used by shell integration

    # List command
    subparsers.add_parser("list", help="List all worktrees")

    # Shell-init command
    subparsers.add_parser("shell-init", help="Print shell integration for eval in .zshrc / .bashrc")

    # Shorthand: bare name/"-" not matching a subcommand → treat as "switch <name>"
    KNOWN_COMMANDS = {"create", "remove", "list", "switch", "shell-init"}
    if (len(sys.argv) > 1
            and sys.argv[1] not in KNOWN_COMMANDS
            and (sys.argv[1] == "-" or not sys.argv[1].startswith("-"))):
        sys.argv[1:] = ["switch"] + sys.argv[1:]
        if _cd_file:
            sys.argv.append(f"--cd-file={_cd_file}")
            _cd_file = None  # consumed

    args = parser.parse_args()
    config = Config()

    _exit_code = 0
    try:
        if args.command == "create":
            cmd_create(args, config)
        elif args.command == "remove":
            cmd_remove(args, config)
        elif args.command == "switch":
            cmd_switch(args)
        elif args.command == "list":
            cmd_list(args)
        elif args.command == "shell-init":
            cmd_shell_init()
    except SystemExit as e:
        _exit_code = e.code if isinstance(e.code, int) else 1
        raise
    finally:
        if _atuin_id:
            try:
                subprocess.run(
                    ["atuin", "history", "end", "--exit", str(_exit_code), _atuin_id],
                    capture_output=True,
                )
            except Exception:
                pass


if __name__ == "__main__":
    main()
