#!/usr/bin/env python3
"""git-wt: Git worktree manager with IDE and dependency setup.

Automates the full lifecycle of git worktrees including dependency installation,
IDE configuration, and environment setup for monorepo development.
"""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import xml.etree.ElementTree as ET
from pathlib import Path
from typing import Dict, List, Optional, Set, Tuple


# --- Configuration ---

class Config:
    """Configuration management with layered precedence."""

    def __init__(self):
        self.editor = "idea"
        self.base_dir = "../worktrees/{repo}"
        self.open_editor = True
        self._load_config_file()
        self._load_env_vars()

    def _load_config_file(self):
        """Load config from ~/.config/git-wt/config."""
        config_path = Path.home() / ".config" / "git-wt" / "config"
        if not config_path.exists():
            return

        try:
            with open(config_path) as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith("#"):
                        continue
                    if "=" in line:
                        key, value = line.split("=", 1)
                        key = key.strip()
                        value = value.strip()
                        if key == "EDITOR":
                            self.editor = value
                        elif key == "BASE_DIR":
                            self.base_dir = value
                        elif key == "OPEN_EDITOR":
                            self.open_editor = value.lower() in ("true", "1", "yes")
        except Exception as e:
            print(f"Warning: Failed to load config file: {e}", file=sys.stderr)

    def _load_env_vars(self):
        """Load config from environment variables."""
        if "GIT_WT_EDITOR" in os.environ:
            self.editor = os.environ["GIT_WT_EDITOR"]
        if "GIT_WT_BASE_DIR" in os.environ:
            self.base_dir = os.environ["GIT_WT_BASE_DIR"]
        if "GIT_WT_OPEN_EDITOR" in os.environ:
            self.open_editor = os.environ["GIT_WT_OPEN_EDITOR"].lower() in ("true", "1", "yes")


# --- Utility Functions ---

def run_cmd(cmd: List[str], cwd: Optional[Path] = None, capture: bool = True, check: bool = True) -> subprocess.CompletedProcess:
    """Run a command and return the result."""
    try:
        return subprocess.run(
            cmd,
            cwd=cwd,
            capture_output=capture,
            text=True,
            check=check
        )
    except subprocess.CalledProcessError as e:
        if check:
            print(f"Error running command: {' '.join(cmd)}", file=sys.stderr)
            if e.stderr:
                print(e.stderr, file=sys.stderr)
            raise
        return e


def get_git_root() -> Path:
    """Get the root directory of the current worktree."""
    result = run_cmd(["git", "rev-parse", "--show-toplevel"])
    return Path(result.stdout.strip())


def get_main_worktree_root() -> Path:
    """Return the main worktree's root directory, even when called from a linked worktree.

    Uses git-common-dir (which points at the shared .git) to find the main worktree,
    so base_dir resolution doesn't nest paths under the current worktree.
    """
    result = run_cmd(["git", "rev-parse", "--path-format=absolute", "--git-common-dir"])
    common_dir = Path(result.stdout.strip())
    if common_dir.name == ".git":
        return common_dir.parent
    return get_git_root()


def get_repo_name() -> str:
    """Get the repository name from the main worktree directory."""
    return get_main_worktree_root().name


def branch_exists_where(branch: str) -> Optional[str]:
    """Return 'local', 'remote', or None."""
    result = run_cmd(["git", "rev-parse", "--verify", branch], check=False)
    if result.returncode == 0:
        return "local"
    result = run_cmd(["git", "rev-parse", "--verify", f"origin/{branch}"], check=False)
    if result.returncode == 0:
        return "remote"
    return None


def find_worktree_for_branch(branch: str) -> Optional[Path]:
    """Return the path of the worktree where branch is checked out, or None."""
    for wt in get_worktrees():
        if wt.get("branch") == branch:
            return wt["path"]
    return None


# --- Project Detection ---

class Project:
    """Represents a detected sub-project."""

    def __init__(self, path: Path, name: str, project_type: str):
        self.path = path
        self.name = name
        self.type = project_type
        self.dependencies: Set[str] = set()

    def __repr__(self):
        return f"Project({self.name}, {self.type})"


def detect_projects(root: Path) -> List[Project]:
    """Detect all sub-projects in the repository."""
    projects = []

    # Check root directory
    root_project = detect_project(root, ".")
    if root_project:
        projects.append(root_project)

    # Check immediate subdirectories
    for item in root.iterdir():
        if item.is_dir() and not item.name.startswith("."):
            project = detect_project(item, item.name)
            if project:
                projects.append(project)

    # Parse Poetry dependencies
    for project in projects:
        if project.type == "poetry":
            parse_poetry_dependencies(project)

    return projects


def detect_project(path: Path, name: str) -> Optional[Project]:
    """Detect the type of a single project directory."""
    pyproject = path / "pyproject.toml"

    # Poetry project
    if pyproject.exists():
        with open(pyproject) as f:
            content = f.read()
            if "[tool.poetry]" in content:
                return Project(path, name, "poetry")
            # pip/uv project with pyproject.toml
            return Project(path, name, "pip")

    # pip project with requirements.txt
    if (path / "requirements.txt").exists():
        return Project(path, name, "pip")

    # npm project
    if (path / "package-lock.json").exists():
        return Project(path, name, "npm")

    # yarn project
    if (path / "yarn.lock").exists():
        return Project(path, name, "yarn")

    # pnpm project
    if (path / "pnpm-lock.yaml").exists():
        return Project(path, name, "pnpm")

    return None


def parse_poetry_dependencies(project: Project):
    """Parse local path dependencies from pyproject.toml."""
    pyproject = project.path / "pyproject.toml"
    if not pyproject.exists():
        return

    with open(pyproject) as f:
        content = f.read()

    # Look for path dependencies like: some-package = { path = "../other-package" }
    pattern = r'(\w+(?:-\w+)*)\s*=\s*\{\s*path\s*=\s*"\.\.\/([^"]+)"'
    for match in re.finditer(pattern, content):
        dep_name = match.group(2)
        project.dependencies.add(dep_name)


def topological_sort(projects: List[Project]) -> List[Project]:
    """Sort projects by dependencies using topological sort."""
    # Create name to project mapping
    by_name = {p.name: p for p in projects}

    # Calculate in-degree
    in_degree = {p.name: 0 for p in projects}
    for project in projects:
        for dep in project.dependencies:
            if dep in in_degree:
                in_degree[project.name] += 1

    # Queue of projects with no dependencies
    queue = [p for p in projects if in_degree[p.name] == 0]
    result = []

    while queue:
        project = queue.pop(0)
        result.append(project)

        # Decrease in-degree for dependents
        for other in projects:
            if project.name in other.dependencies:
                in_degree[other.name] -= 1
                if in_degree[other.name] == 0:
                    queue.append(other)

    # Check for cycles
    if len(result) != len(projects):
        print("Warning: Circular dependencies detected, using default order", file=sys.stderr)
        return projects

    return result


# --- Dependency Installation ---

def get_python_constraint(project_path: Path) -> Optional[str]:
    """Read the Python version constraint from a project's pyproject.toml."""
    pyproject = project_path / "pyproject.toml"
    if not pyproject.exists():
        return None
    try:
        import tomllib
    except ImportError:
        return None
    try:
        with open(pyproject, "rb") as f:
            data = tomllib.load(f)
    except Exception:
        return None
    poetry_val = (
        data.get("tool", {}).get("poetry", {}).get("dependencies", {}).get("python")
    )
    if isinstance(poetry_val, dict):
        poetry_val = poetry_val.get("version")
    if isinstance(poetry_val, str):
        return poetry_val
    pep621 = data.get("project", {}).get("requires-python")
    return pep621 if isinstance(pep621, str) else None


def _cmp_version(a: Tuple[int, ...], b: Tuple[int, ...]) -> int:
    n = max(len(a), len(b))
    a = a + (0,) * (n - len(a))
    b = b + (0,) * (n - len(b))
    return (a > b) - (a < b)


def _match_single_constraint(ver: Tuple[int, ...], spec: str) -> bool:
    import re as _re
    m = _re.match(r'^\s*(==|!=|>=|<=|>|<|~=|~|\^|=)?\s*(\d[\d.]*)\s*$', spec)
    if not m:
        return True
    op = m.group(1) or "=="
    target = tuple(int(p) for p in m.group(2).split("."))
    if op in ("==", "="):
        return ver[:len(target)] == target
    if op == "!=":
        return ver[:len(target)] != target
    if op == ">":
        return _cmp_version(ver, target) > 0
    if op == ">=":
        return _cmp_version(ver, target) >= 0
    if op == "<":
        return _cmp_version(ver, target) < 0
    if op == "<=":
        return _cmp_version(ver, target) <= 0
    if op in ("~", "~="):
        if len(target) >= 2:
            upper = (target[0], target[1] + 1)
        else:
            upper = (target[0] + 1,)
        return _cmp_version(ver, target) >= 0 and _cmp_version(ver, upper) < 0
    if op == "^":
        upper_list = list(target)
        for i, n in enumerate(upper_list):
            if n > 0:
                upper_list[i] = n + 1
                upper_list[i + 1:] = [0] * (len(upper_list) - i - 1)
                break
        return _cmp_version(ver, target) >= 0 and _cmp_version(ver, tuple(upper_list)) < 0
    return True


def _match_constraint(ver: Tuple[int, ...], constraint: str) -> bool:
    specs = [s.strip() for s in constraint.split(",") if s.strip()]
    if not specs:
        return True
    return all(_match_single_constraint(ver, s) for s in specs)


def python_cmd_satisfies(python_cmd: str, constraint: str) -> bool:
    """Check if e.g. 'python3.13' satisfies a version constraint string."""
    import re as _re
    m = _re.match(r'python(\d+)\.(\d+)', python_cmd)
    if not m:
        return False
    ver = (int(m.group(1)), int(m.group(2)))
    return _match_constraint(ver, constraint)


def pick_compatible_python(constraint: str) -> Optional[str]:
    """Return the highest installed python3.X command satisfying the constraint."""
    for minor in range(20, 7, -1):
        cmd = f"python3.{minor}"
        if shutil.which(cmd) and python_cmd_satisfies(cmd, constraint):
            return cmd
    return None


def suggest_python_minor(constraint: str) -> Optional[str]:
    """Return a 'X.Y' version that satisfies the constraint, ignoring what's installed."""
    for minor in range(20, 7, -1):
        if python_cmd_satisfies(f"python3.{minor}", constraint):
            return f"3.{minor}"
    return None


def get_source_python(source_path: Path, project_name: str) -> Optional[str]:
    """Get the Python executable used by a Poetry project in the source worktree."""
    source_project = source_path / project_name
    if not source_project.exists():
        return None

    import re as _re

    # Prefer an in-project .venv if present. Poetry may not know about it
    # (e.g. it was created manually, or global virtualenvs.in-project=false and
    # no local poetry.toml exists), in which case `poetry env info` fails — but
    # the user's day-to-day interpreter is still what the IDE is configured for.
    in_project_python = source_project / ".venv" / "bin" / "python"
    if in_project_python.exists():
        ver_result = run_cmd([str(in_project_python), "--version"], check=False)
        if ver_result.returncode == 0:
            ver_m = _re.match(r'Python (\d+\.\d+)', ver_result.stdout.strip())
            if ver_m:
                return f"python{ver_m.group(1)}"

    try:
        result = run_cmd(["poetry", "env", "info", "--executable"], cwd=source_project, check=False)
        if result.returncode == 0:
            executable = result.stdout.strip()
            real = Path(executable).resolve()
            # Check centralized venv path suffix like "-py3.13"
            m = _re.search(r'-py(\d+\.\d+)', str(real))
            if m:
                return f"python{m.group(1)}"
            # Fallback: ask the executable for its version directly
            # (works for both in-project .venv and centralized venvs)
            ver_result = run_cmd([executable, "--version"], check=False)
            if ver_result.returncode == 0:
                ver_m = _re.match(r'Python (\d+\.\d+)', ver_result.stdout.strip())
                if ver_m:
                    return f"python{ver_m.group(1)}"
    except Exception:
        pass
    return None


def install_dependencies(worktree_path: Path, projects: List[Project], source_path: Optional[Path] = None) -> Dict[str, Path]:
    """Install dependencies for all projects and return venv paths."""
    poetry_projects = [p for p in projects if p.type == "poetry"]
    sorted_poetry = topological_sort(poetry_projects)

    venv_paths = {}

    # Pre-flight: resolve the Python interpreter for every Poetry project up-front.
    # If any project's constraint can't be satisfied by an installed python3.X, abort
    # with install instructions before touching any project.
    plan: Dict[str, tuple[Optional[str], str]] = {}
    missing: List[tuple[str, str, Optional[str]]] = []  # (project_name, constraint, source_python)
    for project in sorted_poetry:
        project_dir = worktree_path / project.name
        source_python = get_source_python(source_path, project.name) if source_path else None
        constraint = get_python_constraint(project_dir)

        if source_python and (not constraint or python_cmd_satisfies(source_python, constraint)):
            plan[project.name] = (source_python, "matching source worktree")
            continue
        if not constraint:
            plan[project.name] = (None, "")
            continue
        pick = pick_compatible_python(constraint)
        if pick:
            reason = (
                f"source {source_python} incompatible with {constraint}"
                if source_python else f"satisfies {constraint}"
            )
            plan[project.name] = (pick, reason)
        else:
            missing.append((project.name, constraint, source_python))

    if missing:
        print("Error: no compatible Python found for one or more projects:", file=sys.stderr)
        suggested_minors = set()
        for name, constraint, src in missing:
            src_note = f"; source uses {src}" if src else ""
            print(f"  - {name}: requires {constraint}{src_note}", file=sys.stderr)
            s = suggest_python_minor(constraint)
            if s:
                suggested_minors.add(s)
        if suggested_minors:
            versions = ", ".join(sorted(suggested_minors))
            print(f"\nInstall a compatible Python ({versions}) via one of:", file=sys.stderr)
            for v in sorted(suggested_minors):
                print(f"  brew install python@{v}", file=sys.stderr)
            for v in sorted(suggested_minors):
                print(f"  pyenv install {v} && pyenv rehash", file=sys.stderr)
            print("\nThen re-run `git wt create` (existing worktree will be reused).", file=sys.stderr)
        sys.exit(1)

    # Install Poetry projects in dependency order
    for project in sorted_poetry:
        print(f"Installing Poetry dependencies for {project.name}...")
        try:
            project_dir = worktree_path / project.name

            # Ensure in-project venvs (creates poetry.toml if not present)
            run_cmd(["poetry", "config", "--local", "virtualenvs.in-project", "true"], cwd=project_dir)

            python_cmd, reason = plan[project.name]
            if python_cmd:
                print(f"  → using {python_cmd} ({reason})")
                run_cmd(["poetry", "env", "use", python_cmd], cwd=project_dir)

            run_cmd(["poetry", "install"], cwd=project_dir)

            # Get venv path
            result = run_cmd(["poetry", "env", "info", "-p"], cwd=project_dir)
            venv_path = Path(result.stdout.strip())
            venv_paths[project.name] = venv_path
            print(f"  → venv at {venv_path}")
        except Exception as e:
            print(f"Warning: Failed to install {project.name}: {e}", file=sys.stderr)

    # Install npm/yarn/pnpm projects
    for project in projects:
        if project.type in ("npm", "yarn", "pnpm"):
            print(f"Installing {project.type} dependencies for {project.name}...")
            try:
                project_dir = worktree_path / project.name
                if project.type == "npm":
                    run_cmd(["npm", "ci"], cwd=project_dir)
                elif project.type == "yarn":
                    run_cmd(["yarn", "install", "--frozen-lockfile"], cwd=project_dir)
                elif project.type == "pnpm":
                    run_cmd(["pnpm", "install", "--frozen-lockfile"], cwd=project_dir)
            except Exception as e:
                print(f"Warning: Failed to install {project.name}: {e}", file=sys.stderr)
        elif project.type == "pip":
            print(f"Installing pip dependencies for {project.name}...")
            try:
                project_dir = worktree_path / project.name
                run_cmd(["pip", "install", "-e", "."], cwd=project_dir)
            except Exception as e:
                print(f"Warning: Failed to install {project.name}: {e}", file=sys.stderr)

    return venv_paths


# --- IDE Setup ---

def get_running_jetbrains_ides() -> List[str]:
    """Return names of running JetBrains IDE processes.

    IntelliJ/PyCharm read jdk.table.xml only at startup and overwrite it on
    shutdown — so any edit made while the IDE is running will be lost. Callers
    should abort before touching the SDK table if this returns a non-empty list.
    """
    names: List[str] = []
    for proc in ("idea", "pycharm"):
        result = run_cmd(["pgrep", "-l", proc], check=False)
        if result.returncode == 0:
            for line in result.stdout.splitlines():
                parts = line.split(None, 1)
                if len(parts) == 2:
                    names.append(parts[1])
    return names


def get_jetbrains_config_dirs() -> List[Path]:
    """Find all active JetBrains config directories."""
    if sys.platform == "darwin":
        base = Path.home() / "Library" / "Application Support" / "JetBrains"
    elif sys.platform == "win32":
        base = Path(os.environ.get("APPDATA", "")) / "JetBrains"
    else:
        base = Path.home() / ".config" / "JetBrains"
    if not base.exists():
        return []
    return sorted(
        [d for d in base.iterdir() if d.is_dir() and (d / "options" / "jdk.table.xml").exists()],
        reverse=True,
    )


def get_worktree_sdk_name(source_sdk_name: str, worktree_path: Path) -> str:
    """Generate a worktree-specific SDK name from the source SDK name."""
    wt_label = worktree_path.name
    return f"{source_sdk_name} [wt:{wt_label}]"


def register_jetbrains_sdks(
    source_path: Path, worktree_path: Path, venv_paths: Dict[str, Path],
) -> Dict[str, str]:
    """Register worktree-specific SDKs in JetBrains' global jdk.table.xml.

    Clones existing SDK entries for each project, replaces venv paths with
    the worktree's venv paths, and gives them worktree-specific names.

    Returns a mapping of source SDK name → worktree SDK name.
    """
    if not venv_paths:
        return {}

    config_dirs = get_jetbrains_config_dirs()
    if not config_dirs:
        return {}

    sdk_name_map: Dict[str, str] = {}
    user_home = str(Path.home())

    for config_dir in config_dirs:
        jdk_table_path = config_dir / "options" / "jdk.table.xml"
        tree = ET.parse(jdk_table_path)
        root = tree.getroot()

        # Find the component that holds JDK entries
        component = root.find(".//component[@name='ProjectJdkTable']")
        if component is None:
            continue

        changed = False
        for project_name, venv_path in venv_paths.items():
            # Find ALL source SDK entries for this project
            source_sdks = []
            for jdk in component.findall("jdk"):
                name_elem = jdk.find("name")
                if name_elem is not None:
                    sdk_name = name_elem.get("value", "")
                    # Match SDKs containing (project_name) but skip existing worktree SDKs
                    if f"({project_name})" in sdk_name and "[wt:" not in sdk_name:
                        source_sdks.append(jdk)

            if not source_sdks:
                continue

            import copy as copy_mod
            for source_sdk in source_sdks:
                source_name = source_sdk.find("name").get("value")
                wt_name = get_worktree_sdk_name(source_name, worktree_path)
                sdk_name_map[source_name] = wt_name

                # Skip if already registered
                already_exists = False
                for jdk in component.findall("jdk"):
                    n = jdk.find("name")
                    if n is not None and n.get("value") == wt_name:
                        already_exists = True
                        break
                if already_exists:
                    continue

                # Clone the SDK entry
                new_sdk = copy_mod.deepcopy(source_sdk)

                # Update name
                new_sdk.find("name").set("value", wt_name)

                # Update homePath
                home_path = new_sdk.find("homePath")
                if home_path is not None:
                    new_home = str(venv_path / "bin" / "python")
                    # Use $USER_HOME$ variable like IntelliJ does
                    new_home = new_home.replace(user_home, "$USER_HOME$")
                    home_path.set("value", new_home)

                # Update venv paths in classPath roots
                source_home = source_sdk.find("homePath")
                if source_home is not None:
                    source_venv_str = source_home.get("value", "").replace("$USER_HOME$", user_home)
                    source_venv_dir = str(Path(source_venv_str).parent.parent)
                    new_venv_dir = str(venv_path)

                    for root_elem in new_sdk.findall(".//root[@url]"):
                        url = root_elem.get("url", "")
                        if source_venv_dir in url.replace("$USER_HOME$", user_home):
                            # Replace venv path, preserving $USER_HOME$
                            old_relative = source_venv_dir.replace(user_home, "$USER_HOME$")
                            new_relative = new_venv_dir.replace(user_home, "$USER_HOME$")
                            root_elem.set("url", url.replace(old_relative, new_relative))

                    # Also update source paths (e.g. sibling-module references)
                    for root_elem in new_sdk.findall(".//root[@url]"):
                        url = root_elem.get("url", "")
                        source_str = str(source_path).replace(user_home, "$USER_HOME$")
                        wt_str = str(worktree_path).replace(user_home, "$USER_HOME$")
                        if source_str in url:
                            root_elem.set("url", url.replace(source_str, wt_str))

                # Generate new UUID and strip ASSOCIATED_PROJECT_PATH so the
                # cloned SDK isn't scoped to the source worktree's project path
                # (which would hide it from the new worktree's project).
                import uuid as uuid_mod
                additional = new_sdk.find("additional")
                if additional is not None:
                    additional.set("SDK_UUID", str(uuid_mod.uuid4()))
                    additional.attrib.pop("ASSOCIATED_PROJECT_PATH", None)

                component.append(new_sdk)
                changed = True

        if changed:
            tree.write(jdk_table_path, xml_declaration=True, encoding="utf-8")
            print(f"  Registered {len([v for v in sdk_name_map.values()])} SDK(s) in {config_dir.name}")

    return sdk_name_map


def unregister_jetbrains_sdks(worktree_path: Path):
    """Remove worktree-specific SDKs from JetBrains' global jdk.table.xml."""
    wt_label = f"[wt:{worktree_path.name}]"

    config_dirs = get_jetbrains_config_dirs()
    for config_dir in config_dirs:
        jdk_table_path = config_dir / "options" / "jdk.table.xml"
        tree = ET.parse(jdk_table_path)
        root = tree.getroot()

        component = root.find(".//component[@name='ProjectJdkTable']")
        if component is None:
            continue

        to_remove = []
        for jdk in component.findall("jdk"):
            name_elem = jdk.find("name")
            if name_elem is not None and wt_label in name_elem.get("value", ""):
                to_remove.append(jdk)

        if to_remove:
            for jdk in to_remove:
                component.remove(jdk)
            tree.write(jdk_table_path, xml_declaration=True, encoding="utf-8")
            print(f"  Removed {len(to_remove)} SDK(s) from {config_dir.name}")


def patch_iml_sdk_names(worktree_path: Path, sdk_name_map: Dict[str, str]):
    """Patch jdkName references in .iml files to use worktree-specific SDK names."""
    if not sdk_name_map:
        return

    for iml in worktree_path.glob("*/*.iml"):
        try:
            tree = ET.parse(iml)
            root = tree.getroot()
            changed = False

            for entry in root.findall(".//orderEntry[@type='jdk']"):
                old_name = entry.get("jdkName", "")
                if old_name in sdk_name_map:
                    entry.set("jdkName", sdk_name_map[old_name])
                    changed = True

            if changed:
                tree.write(iml, xml_declaration=True, encoding="utf-8")
        except Exception as e:
            print(f"Warning: Failed to patch {iml.name}: {e}", file=sys.stderr)


def setup_jetbrains(source_path: Path, worktree_path: Path, venv_paths: Dict[str, Path]):
    """Set up JetBrains IDE configuration."""
    source_idea = source_path / ".idea"
    if not source_idea.exists():
        return

    print("Setting up JetBrains IDE configuration...")
    worktree_idea = worktree_path / ".idea"

    # Files/dirs to skip
    skip = {"workspace.xml", "dataSources", "shelf", "httpRequests"}

    # Copy .idea directory
    worktree_idea.mkdir(exist_ok=True)
    for item in source_idea.iterdir():
        if item.name in skip:
            continue
        dest = worktree_idea / item.name
        if item.is_dir():
            shutil.copytree(item, dest, dirs_exist_ok=True)
        else:
            shutil.copy2(item, dest)

    # Copy RunManager from workspace.xml (Multirun, Docker, npm configs)
    copy_workspace_run_manager(source_idea, worktree_idea)

    # Copy .iml files
    for iml in source_path.glob("*/*.iml"):
        dest_dir = worktree_path / iml.parent.name
        dest_dir.mkdir(exist_ok=True)
        shutil.copy2(iml, dest_dir / iml.name)

    # Register worktree-specific SDKs in IntelliJ's global SDK table
    sdk_name_map = register_jetbrains_sdks(source_path, worktree_path, venv_paths)

    # Patch .iml files to use worktree-specific SDK names
    patch_iml_sdk_names(worktree_path, sdk_name_map)

    # Patch run configurations: SDK_NAME references and absolute venv paths
    run_configs_dir = worktree_idea / "runConfigurations"
    if run_configs_dir.exists():
        for xml_file in run_configs_dir.glob("*.xml"):
            try:
                patch_run_config_paths(xml_file, venv_paths, sdk_name_map)
            except Exception as e:
                print(f"Warning: Failed to patch {xml_file.name}: {e}", file=sys.stderr)


def copy_workspace_run_manager(source_idea: Path, worktree_idea: Path):
    """Copy the RunManager component from workspace.xml.

    Preserves Compound (Multirun), Docker, and npm run configurations which
    are stored in workspace.xml rather than individual runConfigurations/*.xml.
    Strips temporary/generated configs (ad-hoc test runs) and user-specific state.
    """
    import copy as copy_mod

    source_workspace = source_idea / "workspace.xml"
    if not source_workspace.exists():
        return

    tree = ET.parse(source_workspace)
    root = tree.getroot()

    run_manager = None
    for comp in root.findall("component"):
        if comp.get("name") == "RunManager":
            run_manager = copy_mod.deepcopy(comp)
            break

    if run_manager is None:
        return

    # Remove temporary/auto-generated configs (ad-hoc test runs)
    for config in list(run_manager.findall("configuration")):
        if config.get("temporary") == "true" or config.get("nameIsGenerated") == "true":
            run_manager.remove(config)

    # Remove recent_temporary list (user-specific)
    for elem in list(run_manager.findall("recent_temporary")):
        run_manager.remove(elem)

    # Write minimal workspace.xml containing only RunManager
    new_root = ET.Element("project", attrib={"version": "4"})
    new_root.append(run_manager)
    dest_workspace = worktree_idea / "workspace.xml"
    ET.ElementTree(new_root).write(dest_workspace, xml_declaration=True, encoding="utf-8")


def patch_run_config_paths(
    xml_path: Path, venv_paths: Dict[str, Path], sdk_name_map: Optional[Dict[str, str]] = None,
):
    """Patch run configurations: SDK_NAME references and absolute venv paths."""
    tree = ET.parse(xml_path)
    root = tree.getroot()

    config = root.find(".//configuration")
    if config is None:
        return

    changed = False

    # Patch SDK_NAME to use worktree-specific SDK
    if sdk_name_map:
        sdk_name_elem = config.find("option[@name='SDK_NAME']")
        if sdk_name_elem is not None:
            old_sdk = sdk_name_elem.get("value", "")
            if old_sdk in sdk_name_map:
                sdk_name_elem.set("value", sdk_name_map[old_sdk])
                changed = True
                # Force IS_MODULE_SDK=true so IntelliJ resolves the interpreter
                # via the module's .iml (which we also patch). With false,
                # initial load shows a red cross until the config is re-saved.
                ims_elem = config.find("option[@name='IS_MODULE_SDK']")
                if ims_elem is not None and ims_elem.get("value") != "true":
                    ims_elem.set("value", "true")

    # Patch SCRIPT_NAME absolute venv paths
    for option in config.findall("option"):
        name = option.get("name")
        value = option.get("value", "")

        if name == "SCRIPT_NAME" and value.startswith("/"):
            sdk_name_elem = config.find("option[@name='SDK_NAME']")
            if sdk_name_elem is not None:
                # Extract project name from SDK_NAME (e.g. "Python 3.13 (my-service) [wt:...]")
                match = re.search(r'\(([^)]+)\)', sdk_name_elem.get("value", ""))
                if match:
                    service = match.group(1)
                    venv_path = venv_paths.get(service)
                    if venv_path:
                        script_basename = Path(value).name
                        option.set("value", str(venv_path / "bin" / script_basename))
                        changed = True

    if changed:
        tree.write(xml_path, xml_declaration=True, encoding="utf-8")


def setup_vscode(source_path: Path, worktree_path: Path, projects: List[Project], venv_paths: Dict[str, Path]):
    """Set up VS Code configuration."""
    print("Setting up VS Code configuration...")

    vscode_dir = worktree_path / ".vscode"
    vscode_dir.mkdir(exist_ok=True)

    # Copy existing .vscode if present
    source_vscode = source_path / ".vscode"
    if source_vscode.exists():
        for item in source_vscode.iterdir():
            dest = vscode_dir / item.name
            if item.is_file():
                shutil.copy2(item, dest)

    # No patching needed: launch.json uses ${workspaceFolder} which resolves
    # to the worktree root automatically, and in-project .venv directories are
    # at the same relative path in every worktree.


def patch_vscode_launch(launch_config: dict, worktree_path: Path, venv_paths: Dict[str, Path]):
    """Patch python interpreter paths in an existing launch.json in-place.

    Updates the "python" field in each configuration to point to the worktree's
    venv. Matches configs to projects by checking whether the config's "cwd"
    contains the project name, falling back to a name substring match.
    """
    configurations = launch_config.get("configurations", [])
    for config in configurations:
        for project_name, venv_path in venv_paths.items():
            cwd = config.get("cwd", "")
            name = config.get("name", "")
            if project_name in cwd or project_name in name:
                config["python"] = str(venv_path / "bin" / "python")
                break


# --- Environment Files ---

def handle_env_files(source_path: Path, worktree_path: Path, projects: List[Project], copy: bool = False):
    """Handle .env files by symlinking or copying."""
    print(f"{'Copying' if copy else 'Symlinking'} .env files...")

    for project in projects:
        source_project = source_path / project.name
        worktree_project = worktree_path / project.name

        if not source_project.exists():
            continue

        for env_file in source_project.glob(".env*"):
            if not env_file.is_file():
                continue
            name = env_file.name
            # Skip template/dist files — they're committed to git and should remain plain copies
            if name.endswith(".dist") or name.endswith("-dist"):
                dest = worktree_project / name
                if not dest.exists():
                    shutil.copy2(env_file, dest)
                continue
            dest = worktree_project / name
            if copy:
                shutil.copy2(env_file, dest)
            else:
                if dest.exists() or dest.is_symlink():
                    dest.unlink()
                dest.symlink_to(env_file)


def handle_claude_config(source_path: Path, worktree_path: Path):
    """Symlink .claude/ directory so worktrees share Claude Code configuration."""
    source_claude = source_path / ".claude"
    dest_claude = worktree_path / ".claude"

    if not source_claude.is_dir():
        return

    print("Symlinking .claude/ directory...")
    if dest_claude.exists() or dest_claude.is_symlink():
        if dest_claude.is_symlink():
            dest_claude.unlink()
        else:
            shutil.rmtree(dest_claude)
    dest_claude.symlink_to(source_claude)


def handle_tfvars_files(source_path: Path, worktree_path: Path, copy: bool = False):
    """Handle Terraform .tfvars files by symlinking or copying from terraform/ subdir."""
    terraform_source = source_path / "terraform"
    terraform_dest = worktree_path / "terraform"

    if not terraform_source.exists():
        return

    tfvars_files = list(terraform_source.glob("*.tfvars"))
    if not tfvars_files:
        return

    # Skip tracked files — the worktree already has the committed copy,
    # and replacing it with a symlink would show as a type-change in git status.
    untracked = []
    for tfvars_file in tfvars_files:
        check = run_cmd(
            ["git", "ls-files", "--error-unmatch", tfvars_file.name],
            cwd=terraform_source,
            check=False,
        )
        if check.returncode != 0:
            untracked.append(tfvars_file)

    if not untracked:
        return

    print(f"{'Copying' if copy else 'Symlinking'} .tfvars files...")
    terraform_dest.mkdir(parents=True, exist_ok=True)

    for tfvars_file in untracked:
        dest = terraform_dest / tfvars_file.name
        if copy:
            shutil.copy2(tfvars_file, dest)
        else:
            if dest.exists() or dest.is_symlink():
                dest.unlink()
            dest.symlink_to(tfvars_file)


# --- Docker ---

def docker_compose_down(worktree_path: Path):
    """Tear down the worktree's compose project, if any.

    Each `docker compose up` creates a bridge network; without cleanup these
    accumulate and exhaust Docker's address pool. Best-effort: silent if Docker
    isn't available or there's no compose file.
    """
    if not shutil.which("docker"):
        return
    if not any((worktree_path / name).exists()
               for name in ("docker-compose.yml", "docker-compose.yaml",
                            "compose.yml", "compose.yaml")):
        return
    print("Tearing down docker compose project...")
    run_cmd(
        ["docker", "compose", "down", "--remove-orphans"],
        cwd=worktree_path,
        check=False,
    )


