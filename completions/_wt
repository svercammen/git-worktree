#compdef wt

# Zsh completion for the wt shell function (git-wt integration).
# Install: add the following to ~/.zshrc BEFORE compinit:
#   fpath=(~/bin/completions $fpath)

_wt_branches() {
  git worktree list --porcelain 2>/dev/null \
    | awk '/^branch / { gsub("refs/heads/", "", $2); print $2 }'
  echo -
}

# Branches of linked (non-main) worktrees — candidates for `remove`.
_wt_removable_branches() {
  git worktree list --porcelain 2>/dev/null | awk '
    /^worktree / { wt++ }
    /^branch / && wt > 1 { gsub("refs/heads/", "", $2); print $2 }
  '
}

_wt_worktrees() {
  local -a branches
  branches=($(_wt_branches))
  # l:|=* r:|=* enables substring/fuzzy matching: "feat" matches "feature/my-branch"
  compadd -M 'l:|=* r:|=*' -a branches
}

# Complete a remove target: exclude the main worktree and any branches already
# listed earlier on the command line so tab-cycle doesn't re-suggest them.
_wt_remove_targets() {
  local -a branches already filtered
  branches=($(_wt_removable_branches))
  # Already-typed remove args (between the subcommand and the word at cursor)
  if (( CURRENT > 3 )); then
    already=("${(@)words[3,CURRENT-1]}")
  fi
  local b arg skip
  for b in "${branches[@]}"; do
    skip=0
    for arg in "${already[@]}"; do
      if [[ "$b" == "$arg" ]]; then
        skip=1
        break
      fi
    done
    (( skip )) || filtered+=("$b")
  done
  compadd -M 'l:|=* r:|=*' -a filtered
}

_wt() {
  local -a subcommands
  subcommands=(
    'create:create a new worktree'
    'remove:remove one or more worktrees'
    'switch:switch to a worktree by partial name'
    'list:list all worktrees'
    'shell-init:print shell integration code for .zshrc'
  )

  if (( CURRENT == 2 )); then
    _describe 'subcommand' subcommands
    _wt_worktrees
    return
  fi

  case ${words[2]} in
    switch)
      (( CURRENT == 3 )) && _wt_worktrees
      ;;
    remove)
      _wt_remove_targets
      ;;
  esac
}

# fzf ** trigger: `wt switch **<Tab>` or `wt **<Tab>` opens an interactive fzf picker.
# Requires fzf shell integration (source ~/.fzf.zsh or equivalent).
_fzf_complete_wt() {
  _fzf_complete --prompt='worktree> ' --height 40% --reverse --border -- "$@" < <(
    _wt_branches
  )
}

_wt "$@"
